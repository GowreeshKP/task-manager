# Task Manager — Required Environment Variables
# Copy this file to .env.local and fill in your values for local development.
# For Vercel, add these in: Project Settings → Environment Variables

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Required. Your MongoDB connection string (Atlas or self-hosted).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# ── AI Generation ─────────────────────────────────────────────────────────────
# At least one of these is required to enable AI description generation.

# Option A: Google Gemini API key (starts with "AIza")
GEMINI_API_KEY=

# Option B: OpenRouter API key (starts with "sk-or-v1-")
OPENROUTER_API_KEY=

# ── App URL ───────────────────────────────────────────────────────────────────
# The public URL of your deployed app (used in OpenRouter HTTP-Referer header).
# On Vercel this is automatically set to your deployment URL.
APP_URL=https://your-app.vercel.app
